# 🧪 LOCAL DEVELOPMENT CONFIGURATION
# Copy this to .env and adjust values as needed

# ========== DATABASE (Local MySQL) ==========
# Switch to localhost for local development
DB_HOST=localhost
DB_USER=root
DB_PASS=admin123
DB_NAME=authintegrate
DATABASE_URL=mysql://root:admin123@localhost:3306/authintegrate

# ========== SESSION ==========
SESSION_SECRET=your-super-secret-key-change-this-in-production

# ========== NODE ENVIRONMENT ==========
NODE_ENV=development

# ========== APP SETTINGS ==========
PORT=5000
VITE_MODE=development

# 🔥 ========== EMAIL NOTIFICATIONS (PHASE 7) ==========
# For registration confirmation emails
# Leave empty to disable email notifications (development)
# 
# For Gmail:
#   1. Enable 2-Step Verification on your Google Account
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. Use the 16-character app password below (remove spaces)
#
# For other SMTP providers:
#   1. Get SMTP credentials from your provider
#   2. Adjust EMAIL_SERVICE if not Gmail
#
# Example Gmail setup:
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_SERVICE=gmail

# Note: EMAIL_PASSWORD with spaces is normal for Gmail app passwords

# ========== HARDWARE INTEGRATION ==========
# Serial port for hardware (ESP32/Arduino)
# HARDWARE_SERIAL_PORT=COM3
# HARDWARE_BAUD_RATE=115200
# HARDWARE_MODE=SERIAL

# Set to HTTP for development (no hardware)
HARDWARE_MODE=HTTP
