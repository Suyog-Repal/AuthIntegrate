# ========================
# DATABASE (Supabase PostgreSQL)
# ========================
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://postgres:your_password@db.supabaseproject.supabase.co:5432/postgres

# ========================
# JWT Authentication
# ========================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_at_least_64_characters_long

# ========================
# Hardware Authentication
# ========================
# Must be sent by the ESP32 as the 'x-hardware-api-key' header.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required in production. Optional in development (bypassed if not set).
HARDWARE_API_KEY=your_secure_hardware_api_key_here

# ========================
# Email Service (Resend API)
# ========================
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_api_key

# ========================
# Frontend Configuration
# ========================
# URL where frontend is deployed (e.g., https://yourdomain.vercel.app)
FRONTEND_URL=http://localhost:5173

# ========================
# Node.js Environment
# ========================
NODE_ENV=development
PORT=5010
