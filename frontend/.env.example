# ========================
# Frontend Environment Variables
# ========================

# During local development, Vite proxies /api → localhost:5010 automatically.
# Leave this COMMENTED OUT for local dev so the Vite proxy is used.
# VITE_API_URL=http://localhost:5010/api

# In Vercel production, set this to your Render backend URL:
# VITE_API_URL=https://authintegrate-backend.onrender.com/api

# Note: The Socket.IO connection is derived automatically from VITE_API_URL
# (strips /api suffix to get the root). No additional socket variable needed.
